<!DOCTYPE html>
<html>
<head>
    <title>VoxKitchen Report: {{ pipeline_name }}</title>
    <style>
        body { font-family: -apple-system, BlinkMacSystemFont, sans-serif; max-width: 1200px; margin: 0 auto; padding: 20px; color: #333; }
        h1 { border-bottom: 2px solid #2563eb; padding-bottom: 8px; }
        .card { border: 1px solid #e5e7eb; border-radius: 8px; padding: 16px; margin: 16px 0; }
        table { border-collapse: collapse; width: 100%; }
        th, td { border: 1px solid #e5e7eb; padding: 8px 12px; text-align: left; }
        th { background: #f9fafb; font-weight: 600; }
        .ok { color: #16a34a; }
        .incomplete { color: #dc2626; }
        .meta { color: #6b7280; font-size: 0.9em; }
    </style>
</head>
<body>
    <h1>VoxKitchen Pipeline Report</h1>
    <p class="meta">
        <b>Pipeline:</b> {{ pipeline_name }} |
        <b>Run ID:</b> {{ run_id }} |
        <b>Generated:</b> {{ generated_at }}
    </p>

    <div class="card">
        <h2>Overview</h2>
        <p><b>{{ stats.count }}</b> cuts | <b>{{ "%.1f"|format(stats.total_duration_s) }}s</b> total duration | <b>{{ stats.speaker_count }}</b> speakers</p>
        {% if stats.languages %}
        <p><b>Languages:</b> {% for lang, count in stats.languages.items() %}{{ lang }} ({{ count }}){% if not loop.last %}, {% endif %}{% endfor %}</p>
        {% endif %}
    </div>

    {% if duration_chart %}
    <div class="card">
        <h2>Duration Distribution</h2>
        {{ duration_chart | safe }}
    </div>
    {% endif %}

    {% if stages %}
    <div class="card">
        <h2>Pipeline Stages</h2>
        <table>
            <tr><th>Stage</th><th>Status</th><th>Cuts</th></tr>
            {% for s in stages %}
            <tr>
                <td>{{ s.name }}</td>
                <td class="{{ s.status|lower }}">{{ s.status }}</td>
                <td>{{ s.count }}</td>
            </tr>
            {% endfor %}
        </table>
    </div>
    {% endif %}

    {% if stats.metrics_summary %}
    <div class="card">
        <h2>Metrics Summary</h2>
        <table>
            <tr><th>Metric</th><th>Min</th><th>Mean</th><th>P50</th><th>P95</th><th>Max</th></tr>
            {% for metric, vals in stats.metrics_summary.items() %}
            <tr>
                <td>{{ metric }}</td>
                {% for k in ["min", "mean", "p50", "p95", "max"] %}
                <td>{{ "%.3f"|format(vals.get(k, 0)) }}</td>
                {% endfor %}
            </tr>
            {% endfor %}
        </table>
    </div>
    {% endif %}

    <p class="meta" style="margin-top: 32px;">Generated by <a href="https://github.com/voxkitchen/voxkitchen">VoxKitchen</a></p>
</body>
</html>
